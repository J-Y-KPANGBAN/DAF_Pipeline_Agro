{
	"name": "dataflow_agro_silver",
	"properties": {
		"folder": {
			"name": "data_flow_agro"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Bronze_erp_production_parquet",
						"type": "DatasetReference"
					},
					"name": "SilverProduction"
				},
				{
					"dataset": {
						"referenceName": "Bronze_erp_stocks_logistique_txt",
						"type": "DatasetReference"
					},
					"name": "SilverStocksLogistique"
				},
				{
					"dataset": {
						"referenceName": "Bronze_crm_clients_csv",
						"type": "DatasetReference"
					},
					"name": "SilverClients"
				},
				{
					"dataset": {
						"referenceName": "Bronze_crm_commandes_json",
						"type": "DatasetReference"
					},
					"name": "SilverCommandes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable_Silver",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"rejectedDataLinkedService": {
						"referenceName": "AzureBlobStorageIntput",
						"type": "LinkedServiceReference"
					}
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable_Silver",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable_Silver",
						"type": "DatasetReference"
					},
					"name": "sink3"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable_Silver",
						"type": "DatasetReference"
					},
					"name": "sink4",
					"rejectedDataLinkedService": {
						"referenceName": "AzureBlobStorageIntput",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          sap_lot_id as string,",
				"          sap_ordre_fabrication as string,",
				"          site_sap_code as string,",
				"          site_ville as string,",
				"          site_departement as string,",
				"          site_region as string,",
				"          site_type as string,",
				"          ligne_production as string,",
				"          poste_travail as string,",
				"          operateur_matricule as string,",
				"          date_fabrication as string,",
				"          heure_debut as string,",
				"          heure_fin as string,",
				"          semaine_sap as long,",
				"          periode_sap as string,",
				"          espece as string,",
				"          race_elevage as string,",
				"          age_abattage_jours as long,",
				"          certification as string,",
				"          num_elevage as string,",
				"          departement_elevage as string,",
				"          volume_abattu_tetes as long,",
				"          poids_vif_moyen_kg as double,",
				"          poids_carcasse_kg as double,",
				"          poids_abats_kg as double,",
				"          poids_pertes_kg as double,",
				"          rendement_carcasse_pct as double,",
				"          taux_pertes_pct as double,",
				"          temperature_ressuage_c as double,",
				"          temperature_stockage_c as double,",
				"          ph_viande as double,",
				"          conforme_haccp as boolean,",
				"          statut_sap as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> SilverProduction",
				"source(output(",
				"          {wms_mouvement_id|site_code_wms|site_ville|site_region|entrepot_zone|reference_produit|libelle_produit|espece_principale|type_conservation|type_mouvement|sens|quantite_uc|poids_net_kg|poids_brut_kg|unite_conditionnement|type_palette|nb_palettes|temperature_zone_c|dlc_date|dluo_date|numero_lot_wms|sap_lot_reference|date_mouvement|heure_mouvement|operateur_wms|valeur_stock_eur|statut_controle_qualite|observations} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SilverStocksLogistique",
				"source(output(",
				"          {client_id;raison_sociale;segment;pays;region_livraison;site_rattachement;ville_rattachement;contact_nom;contact_email;telephone;date_creation_compte;statut_compte;ca_annuel_eur;conditions_paiement;canal_commande;certif_exigee;nb_commandes_12m;derniere_commande;score_fidelite;commercial_ref} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SilverClients",
				"source(output(",
				"          commande_id as string,",
				"          client_id as string,",
				"          site_expedition as string,",
				"          ville_expedition as string,",
				"          region_expedition as string,",
				"          produit_espece as string,",
				"          reference_produit as string,",
				"          quantite_kg as integer,",
				"          prix_unitaire_eur_kg as double,",
				"          montant_ht_eur as double,",
				"          tva_pct as double,",
				"          montant_ttc_eur as double,",
				"          date_commande as string,",
				"          date_livraison_prev as string,",
				"          date_livraison_reelle as string,",
				"          statut_commande as string,",
				"          transporteur as string,",
				"          numero_bl as string,",
				"          temperature_transport_c as double,",
				"          destination_pays as string,",
				"          certification_produit as string,",
				"          commentaire as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> SilverCommandes",
				"SilverProduction sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: false) ~> sink1",
				"SilverCommandes sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          commande_id,",
				"          client_id,",
				"          site_expedition,",
				"          ville_expedition,",
				"          region_expedition,",
				"          produit_espece,",
				"          reference_produit,",
				"          quantite_kg,",
				"          prix_unitaire_eur_kg,",
				"          montant_ht_eur,",
				"          tva_pct,",
				"          montant_ttc_eur,",
				"          date_commande,",
				"          date_livraison_prev,",
				"          date_livraison_reelle,",
				"          statut_commande,",
				"          transporteur,",
				"          numero_bl,",
				"          temperature_transport_c,",
				"          destination_pays,",
				"          certification_produit,",
				"          commentaire",
				"     )) ~> sink2",
				"SilverStocksLogistique sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink3",
				"SilverClients sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          client_id,",
				"          raison_sociale,",
				"          segment,",
				"          pays,",
				"          region_livraison,",
				"          site_rattachement,",
				"          ville_rattachement,",
				"          contact_nom,",
				"          contact_email,",
				"          telephone,",
				"          date_creation_compte,",
				"          statut_compte,",
				"          ca_annuel_eur,",
				"          conditions_paiement,",
				"          canal_commande,",
				"          certif_exigee,",
				"          nb_commandes_12m,",
				"          derniere_commande,",
				"          score_fidelite,",
				"          commercial_ref",
				"     )) ~> sink4"
			]
		}
	}
}